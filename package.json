{
  "name": "wazefit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WazeFit — SaaS white label para nicho fitness",
  "scripts": {
    "dev:api": "pnpm --filter @wazefit/api dev",
    "deploy:api": "pnpm --filter @wazefit/api deploy",
    "deploy:site": "npx wrangler pages deploy apps/site/out --project-name=wazefit --commit-dirty=true",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.4",
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.0",
    "typescript-eslint": "^8.34.0",
    "vitest": "^4.1.2"
  }
}
